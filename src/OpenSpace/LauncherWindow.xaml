<Window x:Class="OpenSpace.LauncherWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OpenSpace"
        mc:Ignorable="d"
        Title="OpenSpace Launcher"
        Height="720"
        Width="460"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        Closing="Window_Closing">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="OpenSpace Launcher"
                   FontSize="24"
                   FontWeight="Bold"
                   Margin="0,0,0,10"/>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Margin="0,0,0,5">
            <TextBlock Text="Версия: "
                       Foreground="Gray"/>
            <TextBlock x:Name="VersionText"
                       Foreground="Gray"
                       FontWeight="Bold"/>
            <TextBlock x:Name="UpdateStatusText"
                       Foreground="Green"
                       Margin="10,0,0,0"
                       Visibility="Collapsed"/>
        </StackPanel>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    Margin="0,0,0,10">
            <Button x:Name="CheckUpdateButton"
                    Content="Проверить обновления"
                    Width="160"
                    Margin="0,0,10,0"
                    Click="CheckUpdateButton_Click"/>
            <Button x:Name="DownloadUpdateButton"
                    Content="Скачать обновление"
                    Width="160"
                    Visibility="Collapsed"
                    Click="DownloadUpdateButton_Click"/>
            <ProgressBar x:Name="DownloadProgressBar"
                         Width="160"
                         Height="20"
                         Visibility="Collapsed"
                         Minimum="0"
                         Maximum="100"/>
        </StackPanel>

        <TextBlock Grid.Row="3"
                   Text="Настройте горячие клавиши, затем нажмите «Запустить OpenSpace»."
                   TextWrapping="Wrap"
                   Foreground="Gray"
                   Margin="0,0,0,10"/>

        <TextBlock Grid.Row="4"
                   x:Name="HotkeyWarningText"
                   TextWrapping="Wrap"
                   Foreground="OrangeRed"
                   Visibility="Collapsed"
                   Margin="0,0,0,10"/>

        <ScrollViewer Grid.Row="5"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="HotkeysPanel">
                <!-- Hotkey rows will be generated here -->
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="6"
                    Orientation="Horizontal"
                    Margin="0,10,0,10">
            <CheckBox x:Name="StartMinimizedCheckBox"
                      Content="Запускать свёрнутым в трей"
                      Margin="0,0,20,0"/>
            <CheckBox x:Name="CloseToTrayCheckBox"
                      Content="Сворачивать в трей при закрытии"
                      IsChecked="True"/>
        </StackPanel>

        <StackPanel Grid.Row="7"
                    Orientation="Horizontal"
                    Margin="0,0,0,10">
            <CheckBox x:Name="MaintainAspectRatioCheckBox"
                      Content="Сохранять пропорции окон"
                      IsChecked="True"
                      Margin="0,0,20,0"/>
            <CheckBox x:Name="HoverFocusRequiresCtrlCheckBox"
                      Content="Фокус по наведению только с Ctrl"
                      Margin="0,0,20,0"/>
            <TextBlock Text="Задержка наведения (мс):"
                       VerticalAlignment="Center"
                       Margin="0,0,5,0"/>
            <TextBox x:Name="HoverFocusDelayTextBox"
                     Text="500"
                     Width="60"
                     VerticalAlignment="Center"/>
        </StackPanel>

        <StackPanel Grid.Row="8"
                    Orientation="Vertical"
                    Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal"
                        Margin="0,0,0,5">
                <TextBlock Text="Расположение окон:"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"/>
                <ComboBox x:Name="LayoutModeComboBox"
                           Width="160"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <CheckBox x:Name="ShowDesktopIconsCheckBox"
                       Content="Показывать иконки рабочего стола в центре"
                       Margin="0,0,0,5"/>

            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Папка иконок:"
                           VerticalAlignment="Center"
                           Margin="0,0,5,0"/>
                <TextBox x:Name="DesktopIconsFolderTextBox"
                         Width="220"
                         VerticalAlignment="Center"/>
                <Button x:Name="BrowseDesktopIconsFolderButton"
                         Content="Обзор..."
                         Width="70"
                         Margin="5,0,0,0"
                         Click="BrowseDesktopIconsFolderButton_Click"/>
            </StackPanel>
        </StackPanel>

        <TextBlock Grid.Row="9"
                   x:Name="ConflictText"
                   TextWrapping="Wrap"
                   Foreground="OrangeRed"
                   Visibility="Collapsed"
                   Margin="0,0,0,10"/>

        <StackPanel Grid.Row="10"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button x:Name="RefreshButton"
                    Content="Обновить окна"
                    Width="120"
                    Margin="0,0,10,0"
                    Click="RefreshButton_Click"/>
            <Button x:Name="LaunchButton"
                    Content="Запустить OpenSpace"
                    Width="150"
                    Margin="0,0,10,0"
                    Click="LaunchButton_Click"/>
            <Button x:Name="ExitButton"
                    Content="Выход"
                    Width="80"
                    Click="ExitButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
